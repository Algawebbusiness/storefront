# ============================================================================
# Saleor Storefront — Environment Variables
# ============================================================================

# Saleor API URL (required) - keep the trailing slash
NEXT_PUBLIC_SALEOR_API_URL=https://your-instance.saleor.cloud/graphql/

# Storefront URL - set on production for correct canonical URLs and OG images
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Channel slug (required) - your Saleor channel identifier
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# App token (optional) - enables multi-channel builds and server-side operations
# SALEOR_APP_TOKEN=

# ============================================================================
# Rate Limiting (for build-time API calls)
# ============================================================================

# SALEOR_MAX_CONCURRENT_REQUESTS=3    # Max parallel requests to Saleor (default: 3)
# SALEOR_MIN_REQUEST_DELAY_MS=200     # Min delay between requests in ms (default: 200)
# SALEOR_REQUEST_TIMEOUT_MS=15000     # Request timeout in ms (default: 15000)
# NEXT_BUILD_RETRIES=1                # GraphQL retries during build (default: 3)

# ============================================================================
# Webhooks
# ============================================================================

# SALEOR_WEBHOOK_SECRET=              # HMAC secret for verifying Saleor webhooks

# ============================================================================
# Agentic Commerce Protocols (ACP + UCP)
# ============================================================================

# ACP_ENABLED=true                    # Enable ACP endpoints (OpenAI/ChatGPT)
# ACP_API_KEY=                        # API key for ACP requests from OpenAI
# UCP_ENABLED=true                    # Enable UCP endpoints (Google/Gemini)
# UCP_VERSION=2026-01-23              # UCP spec version
# STRIPE_PUBLISHABLE_KEY=             # For UCP payment handler declaration
# AGENT_API_KEYS=key1,key2            # Comma-separated API keys for agent access

# ============================================================================
# OAuth2 Authorization Server (for customer-scoped AI agent access)
# ============================================================================

# OAUTH_JWT_SECRET=                   # Min 32 chars, for signing JWTs (REQUIRED for OAuth)
# OAUTH_CLIENTS=                      # Client registry: id:secret_sha256:redirect_uri1|uri2
# OAUTH_ACCESS_TOKEN_TTL=3600         # Access token lifetime in seconds (default: 1h)
# OAUTH_REFRESH_TOKEN_TTL=2592000     # Refresh token lifetime in seconds (default: 30d)

# ============================================================================
# Zásilkovna / Packeta (Czech shipping)
# ============================================================================

# NEXT_PUBLIC_ZASILKOVNA_API_KEY=     # Zásilkovna widget API key
